# 单机部署示例配置（macOS / Linux）
# 复制为 app.env 后按机器实际情况修改

NODE_ENV=production

# 对外暴露的静态站点
STATIC_HOST=0.0.0.0
STATIC_PORT=4173
STATIC_DIST_DIR=dist

# AI Bridge 建议只绑定到本机，由静态站点做同源代理
AI_BRIDGE_HOST=127.0.0.1
AI_BRIDGE_PORT=8787
AI_PROXY_TARGET=http://127.0.0.1:8787

# 本地 CLI 模型配置（按机器实际情况修改）
LLM_CLI_COMMAND=gemini-internal
LLM_CLI_ARGS=-o text
LLM_CLI_MODE=arg
LLM_CLI_PROMPT_FLAG=-p
LLM_CLI_TIMEOUT_MS=120000

# 如果你使用模板模式，可打开下面这一项并清空上面的 COMMAND / ARGS
# LLM_CLI_TEMPLATE=
